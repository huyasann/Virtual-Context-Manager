+/// VCTX memory proxy config.
+///
+/// Stored in settings as key = "vctx_memory_config".
+#[derive(Debug, Clone, Serialize, Deserialize)]
+#[serde(rename_all = "camelCase")]
+pub struct VctxMemoryConfig {
+    #[serde(default = "default_true")]
+    pub enabled: bool,
+    #[serde(default = "default_vctx_db_path")]
+    pub db_path: String,
+    #[serde(default = "default_vctx_top_k")]
+    pub recall_top_k: usize,
+    #[serde(default = "default_vctx_max_memory_chars")]
+    pub max_memory_chars: usize,
+    #[serde(default = "default_vctx_checkpoint_min_chars")]
+    pub checkpoint_min_chars: usize,
+}
+
+fn default_vctx_db_path() -> String {
+    dirs::home_dir()
+        .unwrap_or_else(|| std::path::PathBuf::from("."))
+        .join(".vctx")
+        .join("memory.db")
+        .to_string_lossy()
+        .to_string()
+}
+
+fn default_vctx_top_k() -> usize {
+    3
+}
+
+fn default_vctx_max_memory_chars() -> usize {
+    2400
+}
+
+fn default_vctx_checkpoint_min_chars() -> usize {
+    1200
+}
+
+impl Default for VctxMemoryConfig {
+    fn default() -> Self {
+        Self {
+            enabled: true,
+            db_path: default_vctx_db_path(),
+            recall_top_k: default_vctx_top_k(),
+            max_memory_chars: default_vctx_max_memory_chars(),
+            checkpoint_min_chars: default_vctx_checkpoint_min_chars(),
+        }
+    }
+}
